    "%.1f %@ × %lld %@" : {
      "comment" : "A sublabel inside the history entry card, showing the weight lifted and the number of repetitions. The first argument is the weight lifted, formatted to one decimal place. The second argument is the string “common.kg”. The fourth argument is the string “common.reps”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$.1f %2$@ × %3$lld %4$@"
          }
        }
      }
    },
    "%lld" : {

    },
    "× %lld %@" : {
      "comment" : "A label that combines a weight value with a repetition count, separated by an asterisk and a space. The argument is the string “common.reps”.",
